{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "command": {
    "check": {
      "template": "Run all pre-commit checks on the codebase (linting, formatting, typechecking). Fix any issues found.",
      "description": "Run all pre-commit checks (lint, format, typecheck)"
    }
  },
  "mcp": {
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "enabled": true,
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "/home/jarmos/.dotfiles", "/home/jarmos/.config"],
      "enabled": true
    }
  }
}
