{
  "function": {
    "prefix": "function",
    "body": [
      "def ${1:name}(${2:params}: ${3:params_type}) -> ${4:return_type}:",
      "    \"\"\"${5:docstring}\"\"\"",
      "    return"
    ]
  },
  "main": {
    "prefix": "main",
    "body": [
      "def main() -> None:",
      "    \"\"\"The entrypoint of the script.\"\"\"",
      "",
      "if __name__ == \"__main__\":",
      "    main()"
    ]
  },
  "pyright": {
    "prefix": "pyright",
    "body": [
      "  # pyright: ignore[${1:settings}]"
    ]
  },
  "test": {
    "prefix": "test",
    "body": [
      "def test_${1:name}(${2:params}) -> None:",
      "    \"\"\"${3:docstring}\"\"\"",
      "    ${4:statement}"
    ]
  }
}
